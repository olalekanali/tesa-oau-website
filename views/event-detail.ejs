<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= event.title %> — TESA OAU</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #0A1628;
      --blue-mid: #0D2657;
      --blue-bright: #1A4FC4;
      --blue-accent: #2563EB;
      --blue-light: #3B82F6;
      --gold: #F59E0B;
      --gold-light: #FCD34D;
      --white: #F8FAFF;
      --gray: #94A3B8;
      --gray-light: #CBD5E1;
      --text-dim: #64748B;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--white);
      color: var(--blue);
      overflow-x: hidden;
    }

    /* ─── HEADER ─────────────────────────── */
    header {
      position: fixed; top: 0; width: 100%; z-index: 999;
      background: rgba(10, 22, 40, 0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(37, 99, 235, 0.3);
      padding: 0 40px;
      display: flex; align-items: center; justify-content: space-between;
      height: 72px;
    }

    .logo {
      display: flex; align-items: center; gap: 12px;
      text-decoration: none;
    }
    .logo-badge {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--blue-bright), var(--blue-light));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px; color: white; letter-spacing: 1px;
      box-shadow: 0 0 20px rgba(37,99,235,0.5);
    }
    .logo-text { color: white; }
    .logo-text strong { display: block; font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 2px; color: var(--blue-light); }
    .logo-text span { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gray); }

    nav { display: flex; gap: 36px; }
    nav a {
      color: var(--gray-light); font-size: 13px; font-weight: 500;
      text-decoration: none; letter-spacing: 1px; text-transform: uppercase;
      transition: color .2s; position: relative;
    }
    nav a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 2px; background: var(--blue-light);
      transition: width .3s;
    }
    nav a:hover { color: white; }
    nav a:hover::after { width: 100%; }

    .header-cta {
      background: var(--blue-accent); color: white;
      border: none; padding: 10px 24px; border-radius: 6px;
      font-size: 13px; font-weight: 600; letter-spacing: 1px;
      text-transform: uppercase; cursor: pointer;
      transition: all .3s; text-decoration: none;
      display: inline-block;
    }
    .header-cta:hover { background: var(--blue-light); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(37,99,235,0.4); }

    /* ─── EVENT DETAIL ──────────────────── */
    .event-detail-section {
      padding: 100px 40px;
      margin-top: 72px;
    }

    .event-detail-container {
      max-width: 900px; margin: 0 auto;
    }

    .event-back {
      display: inline-flex; align-items: center; gap: 6px;
      color: var(--blue-accent); text-decoration: none;
      font-weight: 600; font-size: 14px; margin-bottom: 32px;
      transition: gap .2s;
    }

    .event-back:hover { gap: 10px; }

    .event-header {
      margin-bottom: 40px;
    }

    .event-header-meta {
      display: flex; gap: 20px; align-items: center;
      margin-bottom: 24px; flex-wrap: wrap;
    }

    .event-status-badge {
      display: inline-block;
      background: var(--gold); color: var(--blue);
      padding: 6px 14px; border-radius: 100px;
      font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
    }

    .event-status-badge.live {
      background: #4ADE80; color: white;
    }

    .event-stats {
      display: flex; gap: 24px; flex-wrap: wrap;
    }

    .event-stat {
      display: flex; gap: 8px; align-items: center;
      font-size: 14px; color: var(--text-dim);
    }

    .event-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(36px, 4vw, 52px);
      line-height: 1.2; font-weight: 900;
      color: var(--blue); margin-bottom: 16px;
    }

    .event-description {
      font-size: 16px; line-height: 1.8;
      color: var(--text-dim);
    }

    .event-featured-img {
      height: 400px; background: linear-gradient(135deg, var(--blue-mid), var(--blue-accent));
      border-radius: 16px; margin: 40px 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 100px; overflow: hidden;
    }

    .event-details-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 24px; margin: 40px 0; background: #F1F5FD;
      padding: 32px; border-radius: 16px;
    }

    .detail-item {
      display: flex; gap: 12px;
    }

    .detail-icon {
      width: 40px; height: 40px; border-radius: 50%;
      background: var(--blue-accent); color: white;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }

    .detail-info h3 {
      font-size: 12px; font-weight: 700; letter-spacing: 1px;
      text-transform: uppercase; color: var(--blue-accent); margin-bottom: 4px;
    }

    .detail-info p {
      font-size: 15px; color: var(--blue); line-height: 1.5;
    }

    .event-content {
      font-size: 16px; line-height: 1.9;
      color: var(--blue); margin: 40px 0;
    }

    .event-content h2 {
      font-family: 'Playfair Display', serif;
      font-size: 28px; font-weight: 700;
      color: var(--blue); margin: 32px 0 16px;
    }

    .event-content h3 {
      font-family: 'Playfair Display', serif;
      font-size: 22px; font-weight: 700;
      color: var(--blue); margin: 24px 0 12px;
    }

    .event-content p {
      margin-bottom: 16px;
    }

    .event-content ul, .event-content ol {
      margin: 16px 0 16px 24px;
    }

    .event-content li {
      margin-bottom: 8px;
    }

    .register-section {
      background: linear-gradient(135deg, var(--blue-accent), #1D4ED8);
      padding: 48px; border-radius: 16px; margin-top: 48px;
      text-align: center; color: white;
    }

    .register-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: 32px; margin-bottom: 16px;
    }

    .register-section p {
      font-size: 16px; margin-bottom: 32px; opacity: 0.95;
    }

    .register-btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: white; color: var(--blue-accent);
      padding: 16px 40px; border-radius: 8px;
      font-size: 16px; font-weight: 700; text-decoration: none;
      transition: all .3s; border: none; cursor: pointer;
    }

    .register-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.2);
    }

    .creator-section {
      background: #F1F5FD; padding: 24px;
      border-radius: 12px; margin-top: 48px;
    }

    .creator-label {
      font-size: 12px; letter-spacing: 2px;
      text-transform: uppercase; color: var(--blue-accent);
      font-weight: 700; margin-bottom: 8px;
    }

    .creator-info {
      display: flex; gap: 16px; align-items: center;
    }

    .creator-avatar {
      width: 60px; height: 60px; border-radius: 50%;
      background: linear-gradient(135deg, var(--blue-accent), var(--gold));
      display: flex; align-items: center; justify-content: center;
      font-size: 24px; flex-shrink: 0;
    }

    .creator-details h3 {
      font-family: 'Playfair Display', serif;
      font-size: 16px; font-weight: 700;
      color: var(--blue); margin-bottom: 2px;
    }

    .creator-details p {
      font-size: 13px; color: var(--text-dim);
    }

    .back-to-events {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--blue-accent); color: white;
      padding: 12px 28px; border-radius: 8px;
      font-size: 14px; font-weight: 600; text-decoration: none;
      transition: all .3s; margin-top: 40px;
    }

    .back-to-events:hover {
      background: var(--blue-light); transform: translateY(-2px);
    }

    @media (max-width: 768px) {
      header { padding: 0 20px; }
      nav { gap: 16px; font-size: 11px; }
      .event-detail-section { padding: 60px 20px; }
      .event-featured-img { height: 280px; font-size: 64px; }
      .event-details-grid { grid-template-columns: 1fr; }
      .register-section { padding: 32px 20px; }
    }
  </style>
</head>
<body>
  <!-- HEADER -->
  <header>
    <a href="/" class="logo">
      <div class="logo-badge">TE</div>
      <div class="logo-text">
        <strong>TESA</strong>
        <span>OAU</span>
      </div>
    </a>
    <nav>
      <a href="/">Home</a>
      <a href="/articles">Articles</a>
      <a href="/events">Events</a>
    </nav>
    <a href="/login" class="header-cta">Login</a>
  </header>

  <!-- EVENT DETAIL SECTION -->
  <section class="event-detail-section">
    <div class="event-detail-container">
      <a href="/events" class="event-back">
        <i class="fas fa-arrow-left"></i>
        Back to Events
      </a>

      <div class="event-header">
        <div class="event-header-meta">
          <% if (event.status === 'live') { %>
            <span class="event-status-badge live">Live</span>
          <% } else { %>
            <span class="event-status-badge">Upcoming</span>
          <% } %>
          <div class="event-stats">
            <div class="event-stat">
              <i class="fas fa-calendar"></i>
              <%= new Date(event.date).toLocaleDateString() %>
            </div>
            <% if (event.startTime) { %>
              <div class="event-stat">
                <i class="fas fa-clock"></i>
                <%= event.startTime %>
              </div>
            <% } %>
          </div>
        </div>
        <h1><%= event.title %></h1>
        <p class="event-description"><%= event.description %></p>
      </div>

      <div class="event-featured-img">🚀</div>

      <!-- EVENT DETAILS -->
      <div class="event-details-grid">
        <% if (event.venueLocation || event.location) { %>
          <div class="detail-item">
            <div class="detail-icon">📍</div>
            <div class="detail-info">
              <h3>Location</h3>
              <p><%= event.venueLocation || event.location %></p>
            </div>
          </div>
        <% } %>

        <% if (event.mode) { %>
          <div class="detail-item">
            <div class="detail-icon">🌐</div>
            <div class="detail-info">
              <h3>Mode</h3>
              <p><%= event.mode.charAt(0).toUpperCase() + event.mode.slice(1) %></p>
            </div>
          </div>
        <% } %>

        <% if (event.onlineLink) { %>
          <div class="detail-item">
            <div class="detail-icon">🔗</div>
            <div class="detail-info">
              <h3>Online Link</h3>
              <p><a href="<%= event.onlineLink %>" target="_blank" style="color: inherit;">Join Meeting</a></p>
            </div>
          </div>
        <% } %>
      </div>

      <!-- EVENT CONTENT -->
      <div class="event-content">
        <%- event.description %>
      </div>

      <!-- REGISTRATION SECTION -->
      <% if (event.registrationLink) { %>
        <div class="register-section">
          <h2>Ready to Attend?</h2>
          <p>Secure your spot at this amazing event</p>
          <a href="<%= event.registrationLink %>" target="_blank" class="register-btn">
            Register Now
            <i class="fas fa-arrow-right"></i>
          </a>
        </div>
      <% } %>

      <!-- CREATOR INFO -->
      <% if (event.creator) { %>
        <div class="creator-section">
          <div class="creator-label">Organized by</div>
          <div class="creator-info">
            <div class="creator-avatar">🎯</div>
            <div class="creator-details">
              <h3><%= event.creator.username %></h3>
              <p><%= event.creator.email %></p>
            </div>
          </div>
        </div>
      <% } %>

      <a href="/events" class="back-to-events">
        <i class="fas fa-arrow-left"></i> View All Events
      </a>
    </div>
  </section>
</body>
</html>
