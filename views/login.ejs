<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — TESA OAU</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #0A1628;
      --blue-mid: #0D2657;
      --blue-bright: #1A4FC4;
      --blue-accent: #2563EB;
      --blue-light: #3B82F6;
      --gold: #F59E0B;
      --gold-light: #FCD34D;
      --white: #F8FAFF;
      --gray: #94A3B8;
      --gray-light: #CBD5E1;
      --text-dim: #64748B;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      background: linear-gradient(135deg, var(--blue) 0%, var(--blue-mid) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      position: relative;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(37,99,235,0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(37,99,235,0.08) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
    }

    .glow-1 {
      position: fixed;
      top: -100px;
      right: -100px;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(37,99,235,0.3) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }

    .glow-2 {
      position: fixed;
      bottom: -150px;
      left: -50px;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(245,158,11,0.15) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: 500px;
    }

    .card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(37,99,235,0.2);
      border-radius: 24px;
      padding: 48px 40px;
      backdrop-filter: blur(20px);
      box-shadow: 0 20px 60px rgba(10,22,40,0.3);
      position: relative;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--blue-accent), var(--gold));
      border-radius: 24px 24px 0 0;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      margin-bottom: 32px;
    }

    .logo-badge {
      width: 48px;
      height: 48px;
      background: linear-gradient(135deg, var(--blue-bright), var(--blue-light));
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 24px;
      color: white;
      box-shadow: 0 0 20px rgba(37,99,235,0.5);
    }

    .logo-text {
      color: white;
    }

    .logo-text strong {
      display: block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 24px;
      letter-spacing: 2px;
      color: var(--blue-light);
    }

    .logo-text span {
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gray);
    }

    .header {
      margin-bottom: 32px;
    }

    .header-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 700;
      margin-bottom: 12px;
    }

    .header-tag i {
      color: var(--gold);
    }

    h1 {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      font-weight: 900;
      color: white;
      margin-bottom: 12px;
      line-height: 1.1;
    }

    h1 em {
      font-style: italic;
      color: var(--blue-light);
    }

    .description {
      font-size: 14px;
      color: var(--gray);
      line-height: 1.6;
    }

    .form-group {
      margin-bottom: 20px;
    }

    label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--gray-light);
      margin-bottom: 8px;
    }

    .input-wrap {
      position: relative;
      display: flex;
      align-items: center;
    }

    .input-wrap i {
      position: absolute;
      left: 16px;
      color: var(--gray);
      font-size: 14px;
      pointer-events: none;
      transition: color 0.2s;
    }

    input {
      width: 100%;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 12px;
      padding: 14px 16px 14px 44px;
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s, background 0.2s;
    }

    input::placeholder {
      color: rgba(255,255,255,0.3);
    }

    input:focus {
      border-color: var(--blue-light);
      background: rgba(255,255,255,0.1);
    }

    input:focus ~ i {
      color: var(--blue-light);
    }

    .pwd-toggle {
      position: absolute;
      right: 14px;
      background: none;
      border: none;
      color: var(--gray);
      font-size: 14px;
      cursor: pointer;
      padding: 4px;
      transition: color 0.2s;
      line-height: 1;
    }

    .pwd-toggle:hover {
      color: var(--blue-light);
    }

    .form-footer {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 24px;
      margin-top: -12px;
    }

    .forgot-link {
      font-size: 12px;
      color: var(--gray);
      text-decoration: none;
      transition: color 0.2s;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .forgot-link:hover {
      color: var(--blue-light);
    }

    .alert {
      padding: 14px 16px;
      border-radius: 12px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      line-height: 1.5;
      animation: slideDown 0.3s ease-out;
    }

    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .alert-success {
      background: rgba(34,197,94,0.15);
      border: 1px solid rgba(34,197,94,0.3);
      color: #86efac;
    }

    .alert-error {
      background: rgba(239,68,68,0.15);
      border: 1px solid rgba(239,68,68,0.3);
      color: #fca5a5;
    }

    .alert i {
      font-size: 16px;
      flex-shrink: 0;
    }

    .btn-login {
      width: 100%;
      background: linear-gradient(135deg, var(--blue-accent), var(--blue-light));
      color: white;
      border: none;
      border-radius: 12px;
      padding: 15px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: all 0.3s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(37,99,235,0.4);
    }

    .btn-login:active {
      transform: translateY(0);
    }

    .btn-login.loading {
      opacity: 0.7;
      pointer-events: none;
    }

    .btn-login i {
      transition: transform 0.3s;
    }

    .btn-login.loading i {
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(360deg);
      }
    }

    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 28px 0;
    }

    .divider::before,
    .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(255,255,255,0.1);
    }

    .divider span {
      font-size: 11px;
      color: var(--gray);
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .link-signup {
      text-align: center;
      font-size: 14px;
      color: var(--gray);
    }

    .link-signup a {
      color: var(--blue-light);
      text-decoration: none;
      font-weight: 700;
      transition: color 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    .link-signup a:hover {
      color: var(--gold);
    }

    @media (max-width: 480px) {
      .card {
        padding: 36px 24px;
      }

      h1 {
        font-size: 28px;
      }
    }
  </style>
  <link rel="stylesheet" href="/styles.css">
  <style>
    /* ─── AUTH PAGE LAYOUT ─────────────────── */
    body {
      min-height: 100vh;
      background: var(--blue);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
      position: relative;
      overflow-x: hidden;
    }

    .auth-bg-grid {
      position: fixed; inset: 0; z-index: 0;
      background-image:
        linear-gradient(rgba(37,99,235,0.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(37,99,235,0.07) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
    }
    .auth-glow-1 {
      position: fixed; top: -120px; right: -120px; z-index: 0;
      width: 520px; height: 520px; border-radius: 50%;
      background: radial-gradient(circle, rgba(37,99,235,0.25) 0%, transparent 70%);
      pointer-events: none;
    }
    .auth-glow-2 {
      position: fixed; bottom: -150px; left: -80px; z-index: 0;
      width: 440px; height: 440px; border-radius: 50%;
      background: radial-gradient(circle, rgba(245,158,11,0.1) 0%, transparent 70%);
      pointer-events: none;
    }

    /* ─── AUTH CARD ────────────────────────── */
    .auth-card {
      position: relative; z-index: 1;
      width: 100%; max-width: 460px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(37,99,235,0.25);
      border-radius: 24px;
      padding: 48px 44px;
      backdrop-filter: blur(16px);
    }
    .auth-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--blue-accent), var(--gold));
      border-radius: 24px 24px 0 0;
    }

    /* ─── LOGO ─────────────────────────────── */
    .auth-logo {
      display: flex; align-items: center; gap: 12px;
      text-decoration: none; margin-bottom: 36px;
    }
    .auth-logo-badge {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--blue-bright), var(--blue-light));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 18px; color: white; letter-spacing: 1px;
      box-shadow: 0 0 20px rgba(37,99,235,0.45);
    }
    .auth-logo-text strong {
      display: block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px; letter-spacing: 2px; color: var(--blue-light);
    }
    .auth-logo-text span {
      font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gray);
    }

    /* ─── HEADING ──────────────────────────── */
    .auth-heading { margin-bottom: 32px; }
    .auth-heading .eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--blue-light); font-weight: 700; margin-bottom: 10px;
    }
    .auth-heading .eyebrow i { font-size: 9px; color: var(--gold); }
    .auth-heading h1 {
      font-family: 'Playfair Display', serif;
      font-size: 32px; font-weight: 900;
      color: white; line-height: 1.15;
    }
    .auth-heading h1 em { font-style: italic; color: var(--blue-light); }
    .auth-heading p {
      margin-top: 8px; font-size: 14px;
      color: var(--gray); line-height: 1.6;
    }

    /* ─── FIELD ────────────────────────────── */
    .field { display: flex; flex-direction: column; gap: 7px; margin-bottom: 16px; }
    .field label {
      font-size: 11px; font-weight: 600; color: var(--gray-light);
      letter-spacing: 1px; text-transform: uppercase;
    }
    .field-wrap {
      position: relative; display: flex; align-items: center;
    }
    .field-wrap i.field-icon {
      position: absolute; left: 16px; z-index: 1;
      color: var(--gray); font-size: 14px;
      pointer-events: none; transition: color .2s;
    }
    .field-wrap input {
      width: 100%;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 13px 16px 13px 44px;
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color .2s, background .2s;
    }
    .field-wrap input::placeholder { color: rgba(255,255,255,0.28); }
    .field-wrap input:focus {
      border-color: var(--blue-light);
      background: rgba(255,255,255,0.1);
    }
    .field-wrap:focus-within i.field-icon { color: var(--blue-light); }

    /* password toggle */
    .pwd-toggle {
      position: absolute; right: 14px;
      background: none; border: none;
      color: var(--gray); font-size: 14px; cursor: pointer;
      padding: 4px; transition: color .2s; line-height: 1;
    }
    .pwd-toggle:hover { color: var(--blue-light); }

    /* ─── FORGOT LINK ───────────────────────── */
    .field-extras {
      display: flex; justify-content: flex-end;
      margin-top: -8px; margin-bottom: 20px;
    }
    .forgot-link {
      font-size: 12px; color: var(--gray);
      text-decoration: none; transition: color .2s;
    }
    .forgot-link:hover { color: var(--blue-light); }

    /* ─── SUBMIT ────────────────────────────── */
    .btn-auth {
      width: 100%;
      background: var(--blue-accent); color: white;
      border: none; border-radius: 10px; padding: 15px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px; font-weight: 700; letter-spacing: .5px;
      cursor: pointer; transition: all .3s; margin-top: 4px;
      display: flex; align-items: center; justify-content: center; gap: 10px;
    }
    .btn-auth:hover {
      background: var(--blue-light);
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(37,99,235,0.45);
    }

    /* ─── DIVIDER ───────────────────────────── */
    .auth-divider {
      display: flex; align-items: center; gap: 14px;
      margin: 28px 0;
    }
    .auth-divider::before,
    .auth-divider::after {
      content: ''; flex: 1; height: 1px;
      background: rgba(255,255,255,0.08);
    }
    .auth-divider span { font-size: 11px; color: var(--gray); letter-spacing: 1px; text-transform: uppercase; }

    /* ─── WELCOME BACK STRIP ────────────────── */
    .welcome-strip {
      background: rgba(37,99,235,0.12);
      border: 1px solid rgba(37,99,235,0.25);
      border-radius: 12px;
      padding: 14px 18px;
      margin-bottom: 28px;
      display: flex; align-items: center; gap: 12px;
    }
    .welcome-strip i { color: var(--gold); font-size: 18px; flex-shrink: 0; }
    .welcome-strip p { font-size: 13px; color: var(--gray-light); line-height: 1.5; }
    .welcome-strip strong { color: white; }

    /* ─── ERROR MESSAGE ─────────────────────── */
    .auth-error {
      background: rgba(239,68,68,0.15);
      border: 1px solid rgba(239,68,68,0.35);
      border-radius: 10px; padding: 12px 16px;
      margin-bottom: 20px;
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: #FCA5A5;
    }
    .auth-error i { font-size: 14px; color: #F87171; flex-shrink: 0; }

    /* ─── FOOTER LINK ───────────────────────── */
    .auth-footer {
      text-align: center;
      font-size: 14px; color: var(--gray);
    }
    .auth-footer a {
      color: var(--blue-light); font-weight: 600;
      text-decoration: none; transition: color .2s;
    }
    .auth-footer a:hover { color: var(--gold); }

    @media (max-width: 480px) {
      .auth-card { padding: 36px 24px; }
    }
  </style>
</head>
<body>

  <div class="auth-bg-grid"></div>
  <div class="auth-glow-1"></div>
  <div class="auth-glow-2"></div>

  <div class="auth-card">

    <!-- Logo -->
    <a href="/" class="auth-logo">
      <div class="auth-logo-badge">TESA</div>
      <div class="auth-logo-text">
        <strong>TESA OAU</strong>
        <span>Obafemi Awolowo University</span>
      </div>
    </a>

    <!-- Welcome strip -->
    <div class="welcome-strip">
      <i class="fa-solid fa-hand-wave"></i>
      <p><strong>Welcome back!</strong> Sign in to access events, articles, and your member dashboard.</p>
    </div>

    <!-- Heading -->
    <div class="auth-heading">
      <div class="eyebrow">
        <i class="fa-solid fa-circle fa-xs"></i>
        Member Portal
      </div>
      <h1><em>Log in</em> to your account</h1>
      <p>Enter your credentials to continue.</p>
    </div>

    <!-- Error message (shown when passed from server) -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="auth-error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <%= error %>
      </div>
    <% } %>

    <!-- Login Form -->
    <form action="/login" method="POST">

      <!-- Email -->
      <div class="field">
        <label for="email">Email Address</label>
        <div class="field-wrap">
          <i class="fa-solid fa-envelope field-icon"></i>
          <input type="email" id="email" name="email" placeholder="yourname@oauife.edu.ng"
            required autocomplete="email">
        </div>
      </div>

      <!-- Password -->
      <div class="field">
        <label for="password">Password</label>
        <div class="field-wrap">
          <i class="fa-solid fa-lock field-icon"></i>
          <input type="password" id="password" name="password" placeholder="Your password"
            required autocomplete="current-password">
          <button type="button" class="pwd-toggle" onclick="togglePwd('password', this)" aria-label="Toggle password">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
      </div>

      <!-- Forgot password -->
      <div class="field-extras">
        <a href="/forgot-password" class="forgot-link">
          <i class="fa-regular fa-circle-question"></i> Forgot password?
        </a>
      </div>

      <button type="submit" class="btn-auth">
        <i class="fa-solid fa-arrow-right-to-bracket"></i>
        Log In
      </button>

    </form>

    <div class="auth-divider"><span>or</span></div>

    <div class="auth-footer">
      Don't have an account?
      <a href="/signup"><i class="fa-solid fa-user-plus"></i> Sign up free</a>
    </div>

  </div>

  <script>
    function togglePwd(inputId, btn) {
      const input = document.getElementById(inputId);
      const icon  = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }
  </script>

</body>
</html>
