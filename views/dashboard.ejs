<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — TESA OAU</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/styles.css">
  <style>

    /* ─── SHELL ──────────────────────────────── */
    body {
      min-height: 100vh;
      background: #080F1E;
      font-family: 'DM Sans', sans-serif;
      color: var(--white);
      display: flex;
    }

    /* ─── SIDEBAR ────────────────────────────── */
    .sidebar {
      width: 260px;
      flex-shrink: 0;
      background: rgba(10,22,40,0.97);
      border-right: 1px solid rgba(37,99,235,0.2);
      display: flex;
      flex-direction: column;
      position: fixed;
      inset: 0 auto 0 0;
      z-index: 100;
      padding: 32px 0;
      transition: transform .3s;
    }

    .sidebar-logo {
      display: flex; align-items: center; gap: 12px;
      text-decoration: none;
      padding: 0 28px 32px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      margin-bottom: 24px;
    }
    .sidebar-logo-badge {
      width: 40px; height: 40px;
      background: linear-gradient(135deg, var(--blue-bright), var(--blue-light));
      border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 17px; color: white; letter-spacing: 1px;
      box-shadow: 0 0 16px rgba(37,99,235,0.45);
    }
    .sidebar-logo-text strong {
      display: block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 18px; letter-spacing: 2px; color: var(--blue-light);
    }
    .sidebar-logo-text span {
      font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--gray);
    }

    .sidebar-section-label {
      padding: 0 28px;
      font-size: 9px; font-weight: 700; letter-spacing: 2.5px;
      text-transform: uppercase; color: var(--gray);
      margin-bottom: 6px; margin-top: 20px;
    }

    .sidebar-nav { flex: 1; }

    .nav-link {
      display: flex; align-items: center; gap: 13px;
      padding: 11px 28px;
      color: var(--gray); font-size: 13.5px; font-weight: 500;
      text-decoration: none;
      border-left: 3px solid transparent;
      transition: all .2s;
    }
    .nav-link i { width: 18px; text-align: center; font-size: 14px; }
    .nav-link:hover {
      color: white;
      background: rgba(37,99,235,0.1);
      border-left-color: rgba(37,99,235,0.4);
    }
    .nav-link.active {
      color: white;
      background: rgba(37,99,235,0.15);
      border-left-color: var(--blue-accent);
    }
    .nav-link.active i { color: var(--blue-light); }

    .sidebar-bottom {
      padding: 24px 28px 0;
      border-top: 1px solid rgba(255,255,255,0.06);
      margin-top: 12px;
    }
    .sidebar-user {
      display: flex; align-items: center; gap: 12px;
      margin-bottom: 16px;
    }
    .user-avatar {
      width: 38px; height: 38px; border-radius: 50%;
      background: linear-gradient(135deg, var(--blue-mid), var(--blue-bright));
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; font-weight: 700; color: white;
      flex-shrink: 0;
    }
    .user-info strong { display: block; font-size: 13px; color: white; font-weight: 600; }
    .user-info span { font-size: 11px; color: var(--gray); }

    .logout-btn {
      display: flex; align-items: center; gap: 10px;
      width: 100%; padding: 10px 14px;
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: 9px; color: #FCA5A5;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 600;
      text-decoration: none; cursor: pointer;
      transition: all .2s;
    }
    .logout-btn:hover {
      background: rgba(239,68,68,0.18);
      border-color: rgba(239,68,68,0.4);
      color: #FEE2E2;
    }

    /* ─── MAIN CONTENT ───────────────────────── */
    .main {
      margin-left: 260px;
      flex: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ─── TOP BAR ────────────────────────────── */
    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 20px 40px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      background: rgba(8,15,30,0.9);
      backdrop-filter: blur(10px);
      position: sticky; top: 0; z-index: 50;
    }
    .topbar-left { display: flex; align-items: center; gap: 14px; }
    .topbar-left .breadcrumb {
      font-size: 12px; color: var(--gray); letter-spacing: .5px;
    }
    .topbar-left .breadcrumb span { color: white; }
    .topbar-right { display: flex; align-items: center; gap: 12px; }

    .role-pill {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 5px 14px; border-radius: 100px;
      font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
    }
    .role-pill.admin    { background: rgba(245,158,11,0.15); color: var(--gold);       border: 1px solid rgba(245,158,11,0.3); }
    .role-pill.organiser{ background: rgba(37,99,235,0.15);  color: var(--blue-light); border: 1px solid rgba(37,99,235,0.3); }
    .role-pill.editor   { background: rgba(139,92,246,0.15); color: #A78BFA;           border: 1px solid rgba(139,92,246,0.3); }
    .role-pill.member   { background: rgba(20,184,166,0.15); color: #2DD4BF;           border: 1px solid rgba(20,184,166,0.3); }
    .role-pill i { font-size: 10px; }

    /* ─── PAGE BODY ──────────────────────────── */
    .page-body { padding: 40px; flex: 1; }

    /* ─── HERO GREETING ──────────────────────── */
    .greeting-banner {
      background: linear-gradient(135deg, var(--blue-mid), #0F3080);
      border: 1px solid rgba(37,99,235,0.3);
      border-radius: 20px; padding: 36px 40px;
      position: relative; overflow: hidden;
      margin-bottom: 36px;
      display: flex; align-items: center; justify-content: space-between; gap: 24px;
    }
    .greeting-banner::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(37,99,235,0.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(37,99,235,0.07) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    .greeting-banner::after {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--blue-accent), var(--gold));
    }
    .greeting-text { position: relative; z-index: 1; }
    .greeting-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--blue-light); font-weight: 700; margin-bottom: 10px;
    }
    .greeting-eyebrow .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--gold); animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%,100% { opacity:1; transform:scale(1); }
      50%      { opacity:.5; transform:scale(1.4); }
    }
    .greeting-text h1 {
      font-family: 'Playfair Display', serif;
      font-size: 30px; font-weight: 900; color: white;
      margin-bottom: 6px; line-height: 1.2;
    }
    .greeting-text h1 em { font-style: italic; color: var(--blue-light); }
    .greeting-text p { font-size: 14px; color: var(--gray); max-width: 480px; line-height: 1.6; }

    .greeting-actions { display: flex; gap: 12px; flex-shrink: 0; position: relative; z-index: 1; }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--blue-accent); color: white;
      padding: 11px 22px; border-radius: 9px;
      font-size: 13px; font-weight: 700; letter-spacing: .3px;
      text-decoration: none; transition: all .2s; border: none; cursor: pointer;
    }
    .btn-primary:hover { background: var(--blue-light); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(37,99,235,0.4); }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent; color: var(--gray-light);
      padding: 11px 22px; border-radius: 9px;
      font-size: 13px; font-weight: 600;
      text-decoration: none; transition: all .2s;
      border: 1px solid rgba(255,255,255,0.15);
    }
    .btn-outline:hover { border-color: var(--blue-light); color: white; }

    /* ─── STAT STRIP ─────────────────────────── */
    .stat-strip {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 36px;
    }
    .stat-tile {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 14px; padding: 22px 24px;
      display: flex; align-items: center; gap: 16px;
      transition: border-color .2s;
    }
    .stat-tile:hover { border-color: rgba(37,99,235,0.3); }
    .stat-icon {
      width: 44px; height: 44px; border-radius: 11px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .stat-icon.blue   { background: rgba(37,99,235,0.15);  color: var(--blue-light); }
    .stat-icon.gold   { background: rgba(245,158,11,0.15); color: var(--gold); }
    .stat-icon.purple { background: rgba(139,92,246,0.15); color: #A78BFA; }
    .stat-icon.green  { background: rgba(20,184,166,0.15); color: #2DD4BF; }
    .stat-value { font-family: 'Bebas Neue', sans-serif; font-size: 30px; color: white; line-height: 1; }
    .stat-label { font-size: 11px; color: var(--gray); text-transform: uppercase; letter-spacing: 1px; margin-top: 3px; }

    /* ─── SECTION LABEL ──────────────────────── */
    .section-header {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 20px;
    }
    .section-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 22px; font-weight: 700; color: white;
    }
    .section-header .tag {
      font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
      color: var(--blue-accent); background: rgba(37,99,235,0.1);
      border: 1px solid rgba(37,99,235,0.25);
      padding: 3px 10px; border-radius: 100px;
    }

    /* ─── MANAGEMENT CARDS ───────────────────── */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }

    .mgmt-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 18px; padding: 28px;
      display: flex; flex-direction: column; gap: 20px;
      transition: all .25s; position: relative; overflow: hidden;
    }
    .mgmt-card:hover {
      border-color: rgba(37,99,235,0.35);
      background: rgba(37,99,235,0.06);
      transform: translateY(-3px);
      box-shadow: 0 12px 36px rgba(0,0,0,0.3);
    }
    .mgmt-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      opacity: 0; transition: opacity .25s;
    }
    .mgmt-card:hover::before { opacity: 1; }
    .mgmt-card.card-blue::before   { background: linear-gradient(90deg, var(--blue-accent), var(--blue-light)); }
    .mgmt-card.card-gold::before   { background: linear-gradient(90deg, var(--gold), var(--gold-light)); }
    .mgmt-card.card-purple::before { background: linear-gradient(90deg, #7C3AED, #A78BFA); }

    .card-top { display: flex; align-items: flex-start; justify-content: space-between; }
    .card-icon {
      width: 50px; height: 50px; border-radius: 13px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    .card-icon.blue   { background: rgba(37,99,235,0.15);  color: var(--blue-light); }
    .card-icon.gold   { background: rgba(245,158,11,0.15); color: var(--gold); }
    .card-icon.purple { background: rgba(139,92,246,0.15); color: #A78BFA; }

    .card-badge {
      font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
      padding: 4px 10px; border-radius: 100px;
    }
    .card-badge.admin    { background: rgba(245,158,11,0.1); color: var(--gold);       border: 1px solid rgba(245,158,11,0.25); }
    .card-badge.organiser{ background: rgba(37,99,235,0.1);  color: var(--blue-light); border: 1px solid rgba(37,99,235,0.25); }
    .card-badge.editor   { background: rgba(139,92,246,0.1); color: #A78BFA;           border: 1px solid rgba(139,92,246,0.25); }

    .card-body h3 {
      font-family: 'Playfair Display', serif;
      font-size: 20px; font-weight: 700; color: white; margin-bottom: 8px;
    }
    .card-body p { font-size: 13.5px; color: var(--gray); line-height: 1.65; }

    .card-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: auto; }
    .card-btn-primary {
      display: inline-flex; align-items: center; gap: 7px;
      background: var(--blue-accent); color: white;
      padding: 9px 18px; border-radius: 8px;
      font-size: 12px; font-weight: 700;
      text-decoration: none; transition: all .2s;
    }
    .card-btn-primary:hover { background: var(--blue-light); box-shadow: 0 6px 20px rgba(37,99,235,0.4); }
    .card-btn-ghost {
      display: inline-flex; align-items: center; gap: 7px;
      background: transparent; color: var(--gray-light);
      padding: 9px 18px; border-radius: 8px;
      font-size: 12px; font-weight: 600;
      text-decoration: none; transition: all .2s;
      border: 1px solid rgba(255,255,255,0.12);
    }
    .card-btn-ghost:hover { border-color: var(--blue-light); color: white; }

    /* Gold / purple accent variants */
    .mgmt-card.card-gold .card-btn-primary   { background: var(--gold); color: var(--blue); }
    .mgmt-card.card-gold .card-btn-primary:hover { background: var(--gold-light); box-shadow: 0 6px 20px rgba(245,158,11,0.35); }
    .mgmt-card.card-purple .card-btn-primary { background: #7C3AED; }
    .mgmt-card.card-purple .card-btn-primary:hover { background: #6D28D9; box-shadow: 0 6px 20px rgba(124,58,237,0.4); }

    /* ─── QUICK LINKS ROW ────────────────────── */
    .quick-links {
      display: flex; gap: 12px; flex-wrap: wrap;
      margin-bottom: 40px;
    }
    .quick-link {
      display: inline-flex; align-items: center; gap: 9px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px; padding: 10px 18px;
      font-size: 13px; font-weight: 500; color: var(--gray-light);
      text-decoration: none; transition: all .2s;
    }
    .quick-link i { color: var(--blue-light); font-size: 13px; }
    .quick-link:hover { border-color: rgba(37,99,235,0.35); color: white; background: rgba(37,99,235,0.08); }

    /* ─── MOBILE SIDEBAR TOGGLE ──────────────── */
    .sidebar-toggle {
      display: none;
      position: fixed; top: 16px; left: 16px; z-index: 200;
      width: 40px; height: 40px; border-radius: 9px;
      background: var(--blue-mid); border: 1px solid rgba(37,99,235,0.3);
      color: white; font-size: 16px; cursor: pointer;
      align-items: center; justify-content: center;
    }

    /* ─── RESPONSIVE ─────────────────────────── */
    @media (max-width: 900px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .sidebar-toggle { display: flex; }
      .main { margin-left: 0; }
      .topbar { padding: 16px 20px 16px 68px; }
      .page-body { padding: 24px 20px; }
      .greeting-banner { flex-direction: column; align-items: flex-start; padding: 28px 24px; }
      .cards-grid { grid-template-columns: 1fr; }
      .stat-strip { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .stat-strip { grid-template-columns: 1fr; }
      .greeting-actions { flex-direction: column; width: 100%; }
      .greeting-actions a { justify-content: center; }
    }
  </style>
</head>
<body>

<!-- Mobile sidebar toggle -->
<button class="sidebar-toggle" onclick="document.querySelector('.sidebar').classList.toggle('open')" aria-label="Toggle menu">
  <i class="fa-solid fa-bars"></i>
</button>

<!-- ─── SIDEBAR ──────────────────────────────── -->
<aside class="sidebar">
  <a href="/" class="sidebar-logo">
    <div class="sidebar-logo-badge">TESA</div>
    <div class="sidebar-logo-text">
      <strong>TESA OAU</strong>
      <span>Obafemi Awolowo University</span>
    </div>
  </a>

  <nav class="sidebar-nav">
    <div class="sidebar-section-label">Navigation</div>
    <a href="/dashboard" class="nav-link active">
      <i class="fa-solid fa-house-chimney"></i> Dashboard
    </a>
    <a href="/articles" class="nav-link">
      <i class="fa-solid fa-newspaper"></i> Articles
    </a>
    <a href="/events" class="nav-link">
      <i class="fa-solid fa-calendar-days"></i> Events
    </a>
    <a href="/executives" class="nav-link">
      <i class="fa-solid fa-users"></i> Executives
    </a>

    <% if (user.role === 'admin' || user.role === 'editor') { %>
      <div class="sidebar-section-label">Content</div>
      <a href="/articles/create" class="nav-link">
        <i class="fa-solid fa-pen-nib"></i> New Article
      </a>
    <% } %>
    <% if (user.role === 'admin' || user.role === 'organiser') { %>
      <% if (user.role === 'admin') { } else { %>
        <div class="sidebar-section-label">Content</div>
      <% } %>
      <a href="/events/create" class="nav-link">
        <i class="fa-solid fa-calendar-plus"></i> New Event
      </a>
    <% } %>
    <% if (user.role === 'admin') { %>
      <a href="/executives/create" class="nav-link">
        <i class="fa-solid fa-user-tie"></i> New Executive
      </a>
    <% } %>
  </nav>

  <div class="sidebar-bottom">
    <div class="sidebar-user">
      <div class="user-avatar">
        <%= (user.firstName || user.username).charAt(0).toUpperCase() %>
      </div>
      <div class="user-info">
        <strong><%= user.firstName ? user.firstName + ' ' + (user.lastName || '') : user.username %></strong>
        <span><%= user.email %></span>
      </div>
    </div>
    <a href="/logout" class="logout-btn">
      <i class="fa-solid fa-arrow-right-from-bracket"></i>
      Log Out
    </a>
  </div>
</aside>

<!-- ─── MAIN ──────────────────────────────────── -->
<div class="main">

  <!-- Top bar -->
  <div class="topbar">
    <div class="topbar-left">
      <span class="breadcrumb">TESA OAU &rsaquo; <span>Dashboard</span></span>
    </div>
    <div class="topbar-right">
      <%
        const roleMap = {
          admin:     { label: 'Admin',     icon: 'fa-crown' },
          organiser: { label: 'Organiser', icon: 'fa-calendar-check' },
          editor:    { label: 'Editor',    icon: 'fa-pen-nib' },
          member:    { label: 'Member',    icon: 'fa-user' }
        };
        const roleInfo = roleMap[user.role] || roleMap.member;
      %>
      <span class="role-pill <%= user.role %>">
        <i class="fa-solid <%= roleInfo.icon %>"></i>
        <%= roleInfo.label %>
      </span>
    </div>
  </div>

  <!-- Page body -->
  <div class="page-body">

    <!-- ── Greeting Banner ── -->
    <div class="greeting-banner">
      <div class="greeting-text">
        <div class="greeting-eyebrow">
          <div class="dot"></div>
          Welcome back
        </div>
        <h1>Hello, <em><%= user.firstName || user.username %></em> 👋</h1>
        <p>Manage your events, articles, and team members from one place. Here's a quick overview of what you can do today.</p>
      </div>
      <div class="greeting-actions">
        <a href="/articles" class="btn-primary">
          <i class="fa-solid fa-newspaper"></i> Browse Articles
        </a>
        <a href="/events" class="btn-outline">
          <i class="fa-solid fa-calendar-days"></i> View Events
        </a>
      </div>
    </div>

    <!-- ── Stat Strip ── -->
    <div class="stat-strip">
      <div class="stat-tile">
        <div class="stat-icon blue"><i class="fa-solid fa-newspaper"></i></div>
        <div>
          <div class="stat-value">—</div>
          <div class="stat-label">Articles</div>
        </div>
      </div>
      <div class="stat-tile">
        <div class="stat-icon gold"><i class="fa-solid fa-calendar-days"></i></div>
        <div>
          <div class="stat-value">—</div>
          <div class="stat-label">Events</div>
        </div>
      </div>
      <div class="stat-tile">
        <div class="stat-icon purple"><i class="fa-solid fa-users"></i></div>
        <div>
          <div class="stat-value">—</div>
          <div class="stat-label">Executives</div>
        </div>
      </div>
      <div class="stat-tile">
        <div class="stat-icon green"><i class="fa-solid fa-envelope-open-text"></i></div>
        <div>
          <div class="stat-value">—</div>
          <div class="stat-label">Subscribers</div>
        </div>
      </div>
    </div>

    <!-- ── Management Cards ── -->
    <div class="section-header">
      <h2>Your Tools</h2>
      <span class="tag"><%= roleInfo.label %> Access</span>
    </div>

    <div class="cards-grid">

      <% if (user.role === 'admin') { %>

        <!-- Executives -->
        <div class="mgmt-card card-gold">
          <div class="card-top">
            <div class="card-icon gold"><i class="fa-solid fa-user-tie"></i></div>
            <span class="card-badge admin">Admin</span>
          </div>
          <div class="card-body">
            <h3>Executives</h3>
