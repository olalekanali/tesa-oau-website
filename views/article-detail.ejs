<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= article.title %> — TESA OAU</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #0A1628;
      --blue-mid: #0D2657;
      --blue-bright: #1A4FC4;
      --blue-accent: #2563EB;
      --blue-light: #3B82F6;
      --gold: #F59E0B;
      --gold-light: #FCD34D;
      --white: #F8FAFF;
      --gray: #94A3B8;
      --gray-light: #CBD5E1;
      --text-dim: #64748B;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--white);
      color: var(--blue);
      overflow-x: hidden;
    }

    /* ─── HEADER ─────────────────────────── */
    header {
      position: fixed; top: 0; width: 100%; z-index: 999;
      background: rgba(10, 22, 40, 0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(37, 99, 235, 0.3);
      padding: 0 40px;
      display: flex; align-items: center; justify-content: space-between;
      height: 72px;
    }

    .logo {
      display: flex; align-items: center; gap: 12px;
      text-decoration: none;
    }
    .logo-badge {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--blue-bright), var(--blue-light));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px; color: white; letter-spacing: 1px;
      box-shadow: 0 0 20px rgba(37,99,235,0.5);
    }
    .logo-text { color: white; }
    .logo-text strong { display: block; font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 2px; color: var(--blue-light); }
    .logo-text span { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gray); }

    nav { display: flex; gap: 36px; }
    nav a {
      color: var(--gray-light); font-size: 13px; font-weight: 500;
      text-decoration: none; letter-spacing: 1px; text-transform: uppercase;
      transition: color .2s; position: relative;
    }
    nav a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 2px; background: var(--blue-light);
      transition: width .3s;
    }
    nav a:hover { color: white; }
    nav a:hover::after { width: 100%; }

    .header-cta {
      background: var(--blue-accent); color: white;
      border: none; padding: 10px 24px; border-radius: 6px;
      font-size: 13px; font-weight: 600; letter-spacing: 1px;
      text-transform: uppercase; cursor: pointer;
      transition: all .3s; text-decoration: none;
      display: inline-block;
    }
    .header-cta:hover { background: var(--blue-light); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(37,99,235,0.4); }

    /* ─── ARTICLE DETAIL ─────────────────── */
    .article-detail-section {
      padding: 100px 40px;
      margin-top: 72px;
    }

    .article-detail-container {
      max-width: 800px; margin: 0 auto;
    }

    .article-back {
      display: inline-flex; align-items: center; gap: 6px;
      color: var(--blue-accent); text-decoration: none;
      font-weight: 600; font-size: 14px; margin-bottom: 32px;
      transition: gap .2s;
    }

    .article-back:hover { gap: 10px; }

    .article-header {
      margin-bottom: 40px;
    }

    .article-header-meta {
      display: flex; gap: 20px; align-items: center;
      margin-bottom: 24px; flex-wrap: wrap;
    }

    .article-tag {
      display: inline-block;
      background: var(--blue-accent); color: white;
      padding: 6px 16px; border-radius: 100px;
      font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
    }

    .article-stats {
      display: flex; gap: 16px; font-size: 13px; color: var(--text-dim);
    }

    .article-stat { display: flex; gap: 4px; align-items: center; }

    .article-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(32px, 4vw, 52px);
      line-height: 1.2; font-weight: 900;
      color: var(--blue); margin-bottom: 16px;
    }

    .article-description {
      font-size: 18px; line-height: 1.8;
      color: var(--text-dim);
    }

    .article-featured-img {
      height: 400px; background: linear-gradient(135deg, var(--blue-mid), var(--blue-accent));
      border-radius: 16px; margin: 40px 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 100px; overflow: hidden;
    }

    .article-content {
      font-size: 16px; line-height: 1.9;
      color: var(--blue); margin-bottom: 40px;
    }

    .article-content h2 {
      font-family: 'Playfair Display', serif;
      font-size: 28px; font-weight: 700;
      color: var(--blue); margin: 32px 0 16px;
    }

    .article-content h3 {
      font-family: 'Playfair Display', serif;
      font-size: 22px; font-weight: 700;
      color: var(--blue); margin: 24px 0 12px;
    }

    .article-content p {
      margin-bottom: 16px;
    }

    .article-content ul, .article-content ol {
      margin: 16px 0 16px 24px;
    }

    .article-content li {
      margin-bottom: 8px;
    }

    .article-content blockquote {
      border-left: 4px solid var(--blue-accent);
      padding-left: 20px; margin: 24px 0;
      font-style: italic; color: var(--text-dim);
    }

    .author-section {
      background: #F1F5FD; padding: 24px;
      border-radius: 12px; margin-top: 48px;
    }

    .author-label {
      font-size: 12px; letter-spacing: 2px;
      text-transform: uppercase; color: var(--blue-accent);
      font-weight: 700; margin-bottom: 8px;
    }

    .author-info {
      display: flex; gap: 16px; align-items: center;
    }

    .author-avatar {
      width: 60px; height: 60px; border-radius: 50%;
      background: linear-gradient(135deg, var(--blue-accent), var(--gold));
      display: flex; align-items: center; justify-content: center;
      font-size: 24px; flex-shrink: 0;
    }

    .author-details h3 {
      font-family: 'Playfair Display', serif;
      font-size: 16px; font-weight: 700;
      color: var(--blue); margin-bottom: 2px;
    }

    .author-details p {
      font-size: 13px; color: var(--text-dim);
    }

    .back-to-articles {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--blue-accent); color: white;
      padding: 12px 28px; border-radius: 8px;
      font-size: 14px; font-weight: 600; text-decoration: none;
      transition: all .3s; margin-top: 40px;
    }

    .back-to-articles:hover {
      background: var(--blue-light); transform: translateY(-2px);
    }

    @media (max-width: 768px) {
      header { padding: 0 20px; }
      nav { gap: 16px; font-size: 11px; }
      .article-detail-section { padding: 60px 20px; }
      .article-featured-img { height: 280px; font-size: 64px; }
    }
  </style>
</head>
<body>
  <!-- HEADER -->
  <header>
    <a href="/" class="logo">
      <div class="logo-badge">TE</div>
      <div class="logo-text">
        <strong>TESA</strong>
        <span>OAU</span>
      </div>
    </a>
    <nav>
      <a href="/">Home</a>
      <a href="/articles">Articles</a>
      <a href="/#events">Events</a>
    </nav>
    <a href="/login" class="header-cta">Login</a>
  </header>

  <!-- ARTICLE DETAIL SECTION -->
  <section class="article-detail-section">
    <div class="article-detail-container">
      <a href="/articles" class="article-back">
        <i class="fas fa-arrow-left"></i>
        Back to Articles
      </a>

      <div class="article-header">
        <div class="article-header-meta">
          <span class="article-tag"><%= article.tag || 'Article' %></span>
          <div class="article-stats">
            <div class="article-stat">
              <i class="fas fa-calendar"></i>
              <%= new Date(article.createdAt).toLocaleDateString() %>
            </div>
            <div class="article-stat">
              <i class="fas fa-clock"></i>
              5 min read
            </div>
          </div>
        </div>
        <h1><%= article.title %></h1>
        <p class="article-description"><%= article.description %></p>
      </div>

      <div class="article-featured-img">📰</div>

      <div class="article-content">
        <%- article.text %>
      </div>

      <% if (article.author) { %>
        <div class="author-section">
          <div class="author-label">Written by</div>
          <div class="author-info">
            <div class="author-avatar">✍️</div>
            <div class="author-details">
              <h3><%= article.author.username %></h3>
              <p><%= article.author.email %></p>
            </div>
          </div>
        </div>
      <% } %>

      <a href="/articles" class="back-to-articles">
        <i class="fas fa-arrow-left"></i> View All Articles
      </a>
    </div>
  </section>
</body>
</html>
