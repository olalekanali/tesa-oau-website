<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TESA OAU — Technology & Engineering Students Association</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #0A1628;
      --blue-mid: #0D2657;
      --blue-bright: #1A4FC4;
      --blue-accent: #2563EB;
      --blue-light: #3B82F6;
      --gold: #F59E0B;
      --gold-light: #FCD34D;
      --white: #F8FAFF;
      --gray: #94A3B8;
      --gray-light: #CBD5E1;
      --text-dim: #64748B;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--white);
      color: var(--blue);
      overflow-x: hidden;
    }

    /* ─── HEADER ─────────────────────────── */
    header {
      position: fixed; top: 0; width: 100%; z-index: 999;
      background: rgba(10, 22, 40, 0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(37, 99, 235, 0.3);
      padding: 0 40px;
      display: flex; align-items: center; justify-content: space-between;
      height: 72px;
    }

    .logo {
      display: flex; align-items: center; gap: 12px;
      text-decoration: none;
    }
    .logo-badge {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--blue-bright), var(--blue-light));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px; color: white; letter-spacing: 1px;
      box-shadow: 0 0 20px rgba(37,99,235,0.5);
    }
    .logo-text { color: white; }
    .logo-text strong { display: block; font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 2px; color: var(--blue-light); }
    .logo-text span { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gray); }

    nav { display: flex; gap: 36px; }
    nav a {
      color: var(--gray-light); font-size: 13px; font-weight: 500;
      text-decoration: none; letter-spacing: 1px; text-transform: uppercase;
      transition: color .2s; position: relative;
    }
    nav a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 2px; background: var(--blue-light);
      transition: width .3s;
    }
    nav a:hover { color: white; }
    nav a:hover::after { width: 100%; }

    .header-cta {
      background: var(--blue-accent); color: white;
      border: none; padding: 10px 24px; border-radius: 6px;
      font-size: 13px; font-weight: 600; letter-spacing: 1px;
      text-transform: uppercase; cursor: pointer;
      transition: all .3s; text-decoration: none;
      display: inline-block;
    }
    .header-cta:hover { background: var(--blue-light); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(37,99,235,0.4); }

    /* ─── HERO ───────────────────────────── */
    #home {
      min-height: 100vh;
      background: var(--blue);
      position: relative; overflow: hidden;
      display: flex; align-items: center;
      padding-top: 72px;
    }

    .hero-grid-bg {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(37,99,235,0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(37,99,235,0.08) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .hero-glow-1 {
      position: absolute; top: -100px; right: -100px;
      width: 600px; height: 600px; border-radius: 50%;
      background: radial-gradient(circle, rgba(37,99,235,0.3) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-glow-2 {
      position: absolute; bottom: -150px; left: 10%;
      width: 500px; height: 500px; border-radius: 50%;
      background: radial-gradient(circle, rgba(245,158,11,0.12) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero-inner {
      max-width: 1200px; margin: 0 auto; padding: 80px 40px;
      display: grid; grid-template-columns: 1fr 420px; gap: 80px;
      align-items: center; position: relative; z-index: 2;
    }

    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      background: rgba(37,99,235,0.2); border: 1px solid rgba(37,99,235,0.4);
      padding: 6px 16px; border-radius: 100px; margin-bottom: 32px;
    }
    .hero-eyebrow span { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--blue-light); font-weight: 600; }
    .hero-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.4)} }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(52px, 7vw, 90px);
      line-height: 1.0; font-weight: 900;
      color: white; margin-bottom: 28px;
    }
    .hero-title em { font-style: italic; color: var(--blue-light); }
    .hero-title .gold { color: var(--gold); }

    .hero-desc {
      font-size: 17px; line-height: 1.8; color: var(--gray);
      max-width: 520px; margin-bottom: 48px;
    }

    .hero-btns { display: flex; gap: 16px; flex-wrap: wrap; }
    .btn-primary {
      background: var(--blue-accent); color: white;
      padding: 16px 36px; border-radius: 8px;
      font-size: 14px; font-weight: 600; letter-spacing: .5px;
      text-decoration: none; border: none; cursor: pointer;
      transition: all .3s; display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-primary:hover { background: var(--blue-light); transform: translateY(-2px); box-shadow: 0 12px 32px rgba(37,99,235,0.4); }
    .btn-ghost {
      background: transparent; color: white;
      padding: 16px 36px; border-radius: 8px;
      font-size: 14px; font-weight: 600; letter-spacing: .5px;
      text-decoration: none; border: 1px solid rgba(255,255,255,0.2);
      transition: all .3s; display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-ghost:hover { border-color: var(--blue-light); color: var(--blue-light); }

    .hero-stats {
      display: flex; gap: 40px; margin-top: 56px; padding-top: 40px;
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 42px; color: white; line-height: 1; }
    .stat-num span { color: var(--blue-light); }
    .stat-label { font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--gray); margin-top: 4px; }

    .hero-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(37,99,235,0.3);
      border-radius: 20px; padding: 36px;
      backdrop-filter: blur(10px);
      position: relative; overflow: hidden;
    }
    .hero-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--blue-accent), var(--gold));
    }
    .hero-card h3 { font-family: 'Playfair Display', serif; font-size: 22px; color: white; margin-bottom: 24px; }
    .hero-event-item { padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,0.07); }
    .hero-event-item:last-child { border-bottom: none; }
    .hero-event-date { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--blue-light); margin-bottom: 6px; }
    .hero-event-name { font-size: 14px; font-weight: 600; color: white; margin-bottom: 4px; }
    .hero-event-venue { font-size: 12px; color: var(--gray); }
    .event-badge { display: inline-block; padding: 2px 10px; border-radius: 100px; font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-top: 6px; }
    .badge-upcoming { background: rgba(245,158,11,0.2); color: var(--gold); border: 1px solid rgba(245,158,11,0.3); }
    .badge-live { background: rgba(34,197,94,0.2); color: #4ADE80; border: 1px solid rgba(34,197,94,0.3); }

    /* ─── SECTIONS COMMON ───────────────── */
    section { padding: 100px 40px; }
    .section-inner { max-width: 1200px; margin: 0 auto; }
    .section-tag {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--blue-accent); font-weight: 700; margin-bottom: 16px;
    }
    .section-tag::before { content: ''; width: 24px; height: 2px; background: var(--blue-accent); }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(36px, 4vw, 56px);
      font-weight: 900; line-height: 1.1;
      color: var(--blue); margin-bottom: 16px;
    }
    .section-title em { font-style: italic; color: var(--blue-accent); }

    /* ─── ARTICLES / NEWS SECTION ────────── */
    #articles { background: #F1F5FD; }

    .news-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 56px; }
    .news-header-left { max-width: 500px; }
    .news-header p { font-size: 16px; color: var(--text-dim); line-height: 1.7; margin-top: 12px; }

    .news-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 32px; }

    .featured-article {
      background: white; border-radius: 20px; overflow: hidden;
      box-shadow: 0 4px 30px rgba(10,22,40,0.08);
      transition: transform .3s, box-shadow .3s;
      display: flex; flex-direction: column;
    }
    .featured-article:hover { transform: translateY(-4px); box-shadow: 0 16px 50px rgba(10,22,40,0.15); }
    .featured-img {
      height: 320px; background: linear-gradient(135deg, var(--blue-mid), var(--blue-accent));
      position: relative; overflow: hidden;
    }
    .featured-img-placeholder {
      width: 100%; height: 100%;
      background: linear-gradient(135deg, #0D2657, #1A4FC4, #2563EB);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bebas Neue', sans-serif; font-size: 80px;
      color: rgba(255,255,255,0.15); letter-spacing: 4px;
    }
    .featured-cat {
      position: absolute; top: 20px; left: 20px;
      background: var(--blue-accent); color: white;
      padding: 4px 14px; border-radius: 100px;
      font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
    }
    .featured-body { padding: 36px; flex: 1; display: flex; flex-direction: column; }
    .article-meta { display: flex; gap: 16px; align-items: center; margin-bottom: 16px; }
    .article-meta time { font-size: 12px; color: var(--text-dim); }
    .article-meta .dot { width: 3px; height: 3px; border-radius: 50%; background: var(--gray-light); }
    .featured-body h2 {
      font-family: 'Playfair Display', serif;
      font-size: 26px; font-weight: 700; line-height: 1.3;
      color: var(--blue); margin-bottom: 14px;
    }
    .featured-body p { font-size: 15px; line-height: 1.8; color: var(--text-dim); flex: 1; margin-bottom: 28px; }

    .read-more {
      display: inline-flex; align-items: center; gap: 8px;
      color: var(--blue-accent); font-weight: 700; font-size: 14px;
      text-decoration: none; letter-spacing: .5px;
      transition: gap .2s;
    }
    .read-more:hover { gap: 14px; }

    .news-sidebar { display: flex; flex-direction: column; gap: 20px; }
    .small-article {
      background: white; border-radius: 14px; overflow: hidden;
      box-shadow: 0 2px 16px rgba(10,22,40,0.06);
      transition: all .3s; cursor: pointer;
      display: flex; flex-direction: column;
    }
    .small-article:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(10,22,40,0.12); }
    .small-img {
      height: 90px;
      display: flex; align-items: center; justify-content: center;
      font-size: 32px;
    }
    .small-body { padding: 14px 18px; }
    .small-cat { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--blue-accent); margin-bottom: 6px; }
    .small-body h3 { font-family: 'Playfair Display', serif; font-size: 14px; font-weight: 700; line-height: 1.4; color: var(--blue); margin-bottom: 6px; }
    .small-body time { font-size: 11px; color: var(--text-dim); }

    /* ─── EVENTS SECTION ─────────────────── */
    #events { background: white; }

    .events-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; flex-wrap: wrap; gap: 20px; }
    .events-header-left p { font-size: 16px; color: var(--text-dim); line-height: 1.7; margin-top: 12px; max-width: 480px; }

    .events-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }

    .event-card {
      background: #F8FAFF; border: 1px solid #E2EAF8;
      border-radius: 20px; overflow: hidden;
      transition: all .3s; position: relative;
      display: flex; flex-direction: column;
    }
    .event-card:hover { transform: translateY(-5px); box-shadow: 0 16px 48px rgba(10,22,40,0.12); border-color: rgba(37,99,235,0.28); }

    .event-card-strip {
      height: 130px; position: relative;
      background: linear-gradient(135deg, var(--blue-mid), var(--blue-bright));
      display: flex; align-items: center; justify-content: center;
      font-size: 48px;
    }

    .event-card-body { padding: 22px 24px 26px; flex: 1; display: flex; flex-direction: column; }
    .event-date-badge { font-size: 11px; font-weight: 700; color: var(--blue-accent); letter-spacing: .4px; margin-bottom: 10px; }
    .event-card-body h3 {
      font-family: 'Playfair Display', serif;
      font-size: 17px; font-weight: 700; line-height: 1.4;
      color: var(--blue); margin-bottom: 9px;
    }
    .event-card-body p { font-size: 13px; color: var(--text-dim); line-height: 1.7; flex: 1; margin-bottom: 20px; }
    .event-card-footer {
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 10px; margin-top: auto;
      padding-top: 16px; border-top: 1px solid #E8EEF8;
    }
    .ev-venue { font-size: 12px; color: var(--text-dim); font-weight: 500; }

    .btn-register {
      background: linear-gradient(135deg, var(--blue-accent), #1D4ED8);
      color: white; border: none; border-radius: 9px;
      padding: 9px 18px; font-family: 'DM Sans', sans-serif;
      font-size: 12px; font-weight: 700; cursor: pointer; transition: all .3s;
      display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-register:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,99,235,0.4); }

    /* ─── EXECUTIVES SECTION ─────────────── */
    #executives { background: var(--blue); overflow: hidden; }
    #executives .section-title { color: white; }
    #executives .section-tag { color: var(--gold); }
    #executives .section-tag::before { background: var(--gold); }

    .exec-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 56px; }
    .exec-header p { font-size: 16px; color: var(--gray); line-height: 1.7; margin-top: 12px; max-width: 440px; }

    .carousel-wrapper { position: relative; }
    .carousel-track {
      display: flex; gap: 24px;
      overflow-x: auto; scroll-snap-type: x mandatory;
      scrollbar-width: none; padding-bottom: 8px;
      scroll-behavior: smooth;
    }
    .carousel-track::-webkit-scrollbar { display: none; }

    .exec-card {
      flex: 0 0 260px; scroll-snap-align: start;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(37,99,235,0.2);
      border-radius: 20px; overflow: hidden;
      transition: all .3s; cursor: pointer;
      position: relative;
    }
    .exec-card:hover { transform: translateY(-6px); border-color: rgba(37,99,235,0.5); background: rgba(255,255,255,0.08); }
    .exec-card::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(10,22,40,0.9) 0%, transparent 60%);
      pointer-events: none;
    }
    .exec-photo {
      width: 100%; height: 280px;
      display: flex; align-items: center; justify-content: center;
      position: relative;
    }
    .exec-photo-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      font-size: 72px;
    }
    .exec-info {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 24px 20px; z-index: 2;
    }
    .exec-position { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); font-weight: 700; margin-bottom: 6px; }
    .exec-name { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: white; margin-bottom: 4px; }
    .exec-dept { font-size: 12px; color: var(--gray); }

    .carousel-controls { display: flex; gap: 12px; margin-top: 40px; }
    .carousel-btn {
      width: 48px; height: 48px; border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.2);
      background: transparent; color: white; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; transition: all .3s;
    }
    .carousel-btn:hover { background: var(--blue-accent); border-color: var(--blue-accent); }

    /* ─── NEWSLETTER SECTION ─────────────── */
    #newsletter { background: white; padding: 100px 40px; }
    .subscribe-inner {
      max-width: 1200px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    }
    .subscribe-left .section-title { margin-bottom: 16px; }
    .subscribe-left > p { font-size: 16px; color: var(--text-dim); line-height: 1.8; margin-bottom: 32px; }
    .benefits { display: flex; flex-direction: column; gap: 16px; }
    .benefit { display: flex; align-items: center; gap: 14px; }
    .benefit-icon {
      width: 36px; height: 36px; border-radius: 8px;
      background: rgba(37,99,235,0.1); display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0;
    }
    .benefit span { font-size: 14px; color: var(--text-dim); }

    .subscribe-form-box {
      background: linear-gradient(135deg, var(--blue), var(--blue-mid));
      border-radius: 24px; padding: 48px; position: relative; overflow: hidden;
    }
    .subscribe-form-box::before {
      content: ''; position: absolute; top: -60px; right: -60px;
      width: 200px; height: 200px; border-radius: 50%;
      background: rgba(37,99,235,0.3);
    }
    .subscribe-form-box h3 { font-family: 'Playfair Display', serif; font-size: 28px; color: white; margin-bottom: 8px; position: relative; z-index: 1; }
    .subscribe-form-box > p { font-size: 14px; color: var(--gray); margin-bottom: 32px; position: relative; z-index: 1; }
    .form-group { display: flex; flex-direction: column; gap: 14px; position: relative; z-index: 1; }
    .form-row { display: flex; flex-direction: column; gap: 6px; }
    .form-row label { font-size: 12px; font-weight: 600; color: var(--gray-light); letter-spacing: 1px; text-transform: uppercase; }
    .form-row input, .form-row select {
      background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
      border-radius: 10px; padding: 14px 18px;
      color: white; font-family: 'DM Sans', sans-serif; font-size: 14px;
      outline: none; transition: border-color .2s; width: 100%;
    }
    .form-row input::placeholder { color: rgba(255,255,255,0.3); }
    .form-row input:focus, .form-row select:focus { border-color: var(--blue-light); }
    .form-row select option { background: var(--blue-mid); color: white; }
    .btn-submit {
      width: 100%; background: var(--gold); color: var(--blue);
      border: none; border-radius: 10px; padding: 16px;
      font-size: 15px; font-weight: 700; cursor: pointer;
      transition: all .3s; letter-spacing: .5px; margin-top: 4px;
      font-family: 'DM Sans', sans-serif;
    }
    .btn-submit:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(245,158,11,0.4); }
    .privacy-note { font-size: 11px; color: var(--gray); text-align: center; margin-top: 16px; position: relative; z-index: 1; }

    /* ─── FOOTER ─────────────────────────── */
    footer {
      background: #050D1A;
      color: var(--gray);
      padding: 80px 40px 40px;
    }
    .footer-inner { max-width: 1200px; margin: 0 auto; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; margin-bottom: 60px; }
    .footer-brand p { font-size: 14px; line-height: 1.8; margin: 20px 0 28px; max-width: 300px; }
    .social-links { display: flex; gap: 12px; }
    .social-link {
      width: 40px; height: 40px; border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.1);
      display: flex; align-items: center; justify-content: center;
      color: var(--gray); font-size: 16px; transition: all .3s;
      text-decoration: none;
    }
    .social-link:hover { border-color: var(--blue-accent); color: var(--blue-accent); background: rgba(37,99,235,0.1); }
    .footer-col h4 { font-size: 13px; font-weight: 700; color: white; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 20px; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .footer-col ul li a { color: var(--gray); font-size: 14px; text-decoration: none; transition: color .2s; }
    .footer-col ul li a:hover { color: var(--blue-light); }
    .footer-divider { height: 1px; background: rgba(255,255,255,0.07); margin-bottom: 32px; }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
    .footer-bottom p { font-size: 13px; }
    .footer-bottom a { color: var(--blue-light); text-decoration: none; }
    .oau-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(37,99,235,0.15); border: 1px solid rgba(37,99,235,0.3);
      padding: 6px 16px; border-radius: 100px;
      font-size: 12px; color: var(--blue-light); font-weight: 600;
    }

    /* Toast */
    .toast {
      position: fixed; bottom: 32px; right: 32px; z-index: 9999;
      background: #10B981; color: white; padding: 16px 24px;
      border-radius: 12px; box-shadow: 0 8px 30px rgba(16,185,129,0.4);
      font-size: 14px; font-weight: 600; transform: translateY(100px); opacity: 0;
      transition: all .4s cubic-bezier(.34,1.56,.64,1);
      display: flex; align-items: center; gap: 10px;
    }
    .toast.show { transform: translateY(0); opacity: 1; }

    /* ─── RESPONSIVE ─────────────────────── */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; gap: 40px; }
      .hero-card { display: none; }
      .news-grid { grid-template-columns: 1fr; }
      .news-sidebar { flex-direction: row; overflow-x: auto; }
      .small-article { flex: 0 0 260px; }
      .events-grid { grid-template-columns: 1fr 1fr; }
      .subscribe-inner { grid-template-columns: 1fr; gap: 40px; }
      .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; }
      nav { display: none; }
    }
    @media (max-width: 600px) {
      .events-grid { grid-template-columns: 1fr; }
      header { padding: 0 20px; }
      section { padding: 80px 20px; }
    }
  </style>
</head>
<body>

<!-- TOAST -->
<div class="toast" id="toast">✓ Subscribed! Welcome to TESA OAU</div>

<!-- ─── HEADER ─────────────────────────── -->
<header>
  <a href="#home" class="logo">
    <div class="logo-badge">TESA</div>
    <div class="logo-text">
      <strong>TESA OAU</strong>
      <span>Obafemi Awolowo University</span>
    </div>
  </a>
  <nav>
    <a href="#home">Home</a>
    <a href="#articles">News</a>
    <a href="#events">Events</a>
    <a href="#executives">Executives</a>
    <a href="#newsletter">Newsletter</a>
  </nav>
  <a href="#newsletter" class="header-cta">Join Us</a>
</header>

<!-- ─── HERO ─────────────────────────── -->
<section id="home">
  <div class="hero-grid-bg"></div>
  <div class="hero-glow-1"></div>
  <div class="hero-glow-2"></div>
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">
        <div class="hero-dot"></div>
        <span>OAU's Premier Technology and Engineering Community</span>
      </div>
      <h1 class="hero-title">
        Where <em>Engineers</em><br>
        Build the<br>
        <span class="gold">Future.</span>
      </h1>
      <p class="hero-desc">
        TESA OAU unites technology and engineering students at Obafemi Awolowo University — fostering innovation, professional development, and lifelong connections across every department.
      </p>
      <div class="hero-btns">
        <a href="#executives" class="btn-primary">
          Meet the Team
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#articles" class="btn-ghost">
          Read Articles
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-num">2<span>K+</span></div>
          <div class="stat-label">Members</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">15<span>+</span></div>
          <div class="stat-label">Departments</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">40<span>+</span></div>
          <div class="stat-label">Events / Year</div>
        </div>
      </div>
    </div>

    <!-- Hero Card: shows first 3 upcoming events -->
    <div class="hero-card">
      <h3>Upcoming Events 🗓</h3>
      <% events.slice(0, 3).forEach(event => { %>
        <div class="hero-event-item">
          <div class="hero-event-date"><%= event.date || 'Coming Soon' %></div>
          <div class="hero-event-name"><%= event.title %></div>
          <div class="hero-event-venue">📍 <%= event.venue || event.location || 'TBA' %></div>
          <span class="event-badge badge-upcoming">Upcoming</span>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ─── ARTICLES / NEWS SECTION ─────────── -->
<section id="articles">
  <div class="section-inner">
    <div class="news-header">
      <div class="news-header-left">
        <div class="section-tag">Latest News</div>
        <h2 class="section-title">Stories from<br><em>Our Community</em></h2>
        <p>Stay updated with the latest happenings, achievements, and announcements from TESA OAU.</p>
      </div>
      <a href="/articles" class="read-more" style="font-size:15px">
        View All Articles
        <i class="fas fa-arrow-right"></i>
      </a>
    </div>

    <div class="news-grid">
      <!-- Featured Article (first article) -->
      <% if (articles.length > 0) { %>
        <div class="featured-article">
          <div class="featured-img">
            <div class="featured-img-placeholder">TESA</div>
            <div class="featured-cat">Featured</div>
          </div>
          <div class="featured-body">
            <div class="article-meta">
              <time><%= articles[0].date || 'Recent' %></time>
              <div class="dot"></div>
              <span><%= articles[0].readTime || '5 min read' %></span>
            </div>
            <h2><%= articles[0].title %></h2>
            <p><%= articles[0].description %></p>
            <a href="/articles/<%= articles[0]._id %>" class="read-more">
              Read Full Article
              <i class="fas fa-arrow-right"></i>
            </a>
          </div>
        </div>
      <% } %>

      <!-- Sidebar: remaining articles -->
      <div class="news-sidebar">
        <% articles.slice(1).forEach(article => { %>
          <a href="/articles/<%= article._id %>" class="small-article" style="text-decoration: none; color: inherit; cursor: pointer;">
            <div class="small-img" style="background: linear-gradient(135deg, #0D2657, #1A4FC4)">📰</div>
            <div class="small-body">
              <div class="small-cat"><%= article.tag || 'Article' %></div>
              <h3><%= article.title %></h3>
              <time><%= new Date(article.createdAt).toLocaleDateString() %></time>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<!-- ─── EVENTS SECTION ─────────────────── -->
<section id="events">
  <div class="section-inner">
    <div class="events-header">
      <div class="events-header-left">
        <div class="section-tag">Events</div>
        <h2 class="section-title">What's <em>Happening</em><br>at TESA OAU</h2>
        <p>From intensive workshops to career fairs — explore all our events, past and upcoming.</p>
      </div>
      <a href="/events" class="read-more" style="font-size:15px">
        View All Events
        <i class="fas fa-arrow-right"></i>
      </a>
    </div>

    <div class="events-grid">
      <% events.forEach(event => { %>
        <a href="/events/<%= event._id %>" class="event-card" style="text-decoration: none; color: inherit; cursor: pointer;">
          <div class="event-card-strip">
            🚀
          </div>
          <div class="event-card-body">
            <div class="event-date-badge"><%= new Date(event.date).toLocaleDateString() %></div>
            <h3><%= event.title %></h3>
            <p><%= event.description %></p>
            <div class="event-card-footer">
              <div class="ev-venue">📍 <%= event.venueLocation || event.location || 'TBA' %></div>
              <button class="btn-register">
                View Details
                <i class="fas fa-arrow-right"></i>
              </button>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- ─── EXECUTIVES SECTION ─────────────── -->
<section id="executives">
  <div class="section-inner">
    <div class="exec-header">
      <div>
        <div class="section-tag">Leadership</div>
        <h2 class="section-title">Meet the TESA<br><em>Executives</em></h2>
        <p>The dedicated student leaders driving TESA OAU's mission of innovation and excellence.</p>
      </div>
      <div class="carousel-controls">
        <button class="carousel-btn" onclick="scrollCarousel(-1)" aria-label="Previous">&#8592;</button>
        <button class="carousel-btn" onclick="scrollCarousel(1)" aria-label="Next">&#8594;</button>
      </div>
    </div>

    <div class="carousel-wrapper">
      <div class="carousel-track" id="execCarousel">

        <div class="exec-card">
          <div class="exec-photo">
            <div class="exec-photo-placeholder" style="background:linear-gradient(160deg,#0D2657,#1A4FC4)">👨‍💼</div>
          </div>
          <div class="exec-info">
            <div class="exec-position">President</div>
            <div class="exec-name">ALIYU Ali Olalekan</div>
            <div class="exec-dept">Chemical Engineering</div>
          </div>
        </div>

        <div class="exec-card">
          <div class="exec-photo">
            <div class="exec-photo-placeholder" style="background:linear-gradient(160deg,#1A1A2E,#4F46E5)">👩‍💼</div>
          </div>
          <div class="exec-info">
            <div class="exec-position">Vice President</div>
            <div class="exec-name">Chioma Nwosu</div>
            <div class="exec-dept">Electrical Engineering</div>
          </div>
        </div>

        <div class="exec-card">
          <div class="exec-photo">
            <div class="exec-photo-placeholder" style="background:linear-gradient(160deg,#064E3B,#065F46)">👨‍💻</div>
          </div>
          <div class="exec-info">
            <div class="exec-position">General Secretary</div>
            <div class="exec-name">Ibrahim Musa</div>
            <div class="exec-dept">Computer Engineering</div>
          </div>
        </div>

        <div class="exec-card">
          <div class="exec-photo">
            <div class="exec-photo-placeholder" style="background:linear-gradient(160deg,#7C2D12,#9A3412)">👩‍🔬</div>
          </div>
          <div class="exec-info">
            <div class="exec-position">Financial Secretary</div>
            <div class="exec-name">Blessing Okafor</div>
            <div class="exec-dept">Chemical Engineering</div>
          </div>
        </div>

        <div class="exec-card">
          <div class="exec-photo">
            <div class="exec-photo-placeholder" style="background:linear-gradient(160deg,#312E81,#5B21B6)">👨‍🎨</div>
          </div>
          <div class="exec-info">
            <div class="exec-position">Public Relations Officer</div>
            <div class="exec-name">Seun Adeleke</div>
            <div class="exec-dept">Civil Engineering</div>
          </div>
        </div>

        <div class="exec-card">
          <div class="exec-photo">
            <div class="exec-photo-placeholder" style="background:linear-gradient(160deg,#134E4A,#0F766E)">👩‍🏫</div>
          </div>
          <div class="exec-info">
            <div class="exec-position">Academic Director</div>
            <div class="exec-name">Fatima Abdullahi</div>
            <div class="exec-dept">Systems Engineering</div>
          </div>
        </div>

        <div class="exec-card">
          <div class="exec-photo">
            <div class="exec-photo-placeholder" style="background:linear-gradient(160deg,#1C1917,#44403C)">👨‍🚀</div>
          </div>
          <div class="exec-info">
            <div class="exec-position">Social Director</div>
            <div class="exec-name">Emeka Igwe</div>
            <div class="exec-dept">Agricultural Engineering</div>
          </div>
        </div>

        <div class="exec-card">
          <div class="exec-photo">
            <div class="exec-photo-placeholder" style="background:linear-gradient(160deg,#450A0A,#991B1B)">👩‍💡</div>
          </div>
          <div class="exec-info">
            <div class="exec-position">Tech Director</div>
            <div class="exec-name">Yewande Fashola</div>
            <div class="exec-dept">Electronic Engineering</div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ─── NEWSLETTER SECTION ─────────────── -->
<section id="newsletter">
  <div class="subscribe-inner">
    <div class="subscribe-left">
      <div class="section-tag">Newsletter</div>
      <h2 class="section-title">Never Miss a<br><em>TESA Update</em></h2>
      <p>Be the first to know about events, opportunities, research breakthroughs, and everything happening in TESA OAU's vibrant engineering community.</p>
      <div class="benefits">
        <div class="benefit">
          <div class="benefit-icon">📰</div>
          <span>Weekly curated articles from our editorial team</span>
        </div>
        <div class="benefit">
          <div class="benefit-icon">🎯</div>
          <span>Exclusive event invitations & early registration</span>
        </div>
        <div class="benefit">
          <div class="benefit-icon">💼</div>
          <span>Internship & career opportunities for members</span>
        </div>
        <div class="benefit">
          <div class="benefit-icon">🏆</div>
          <span>Competition alerts & scholarship announcements</span>
        </div>
      </div>
    </div>

    <div class="subscribe-form-box">
      <h3>Stay in the Loop</h3>
      <p>Join 1,200+ students already subscribed.</p>
      <form action="/subscribe" method="POST">
        <div class="form-group">
          <div class="form-row">
            <label for="sub-name">Full Name</label>
            <input type="text" id="sub-name" name="name" placeholder="e.g. Adaeze Okonkwo" required>
          </div>
          <div class="form-row">
            <label for="sub-email">OAU Email Address</label>
            <input type="email" id="sub-email" name="email" placeholder="yourname@oauife.edu.ng" required>
          </div>
          <div class="form-row">
            <label for="sub-dept">Department</label>
            <select id="sub-dept" name="department">
              <option value="">Select your department</option>
              <option>Mechanical Engineering</option>
              <option>Electrical Engineering</option>
              <option>Food Science & Technology</option>
              <option>Aerospace Engineering</option>
              <option>Civil Engineering</option>
              <option>Electronic Engineering</option>
              <option>Agricultural Engineering</option>
              <option>Materials Engineering</option>
              <option>Other</option>
            </select>
          </div>
          <button type="submit" class="btn-submit">Subscribe to Newsletter 🚀</button>
        </div>
      </form>
      <p class="privacy-note">🔒 No spam, ever. Unsubscribe anytime.</p>
    </div>
  </div>
</section>

<!-- ─── FOOTER ─────────────────────────── -->
<footer>
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="#home" class="logo">
          <div class="logo-badge">TESA</div>
          <div class="logo-text">
            <strong>TESA OAU</strong>
            <span>Obafemi Awolowo University</span>
          </div>
        </a>
        <p>The Technology & Engineering Students Association at Obafemi Awolowo University — building the next generation of African engineers and innovators since 1985.</p>
        <div class="social-links">
          <a href="#" class="social-link" title="Twitter/X">𝕏</a>
          <a href="#" class="social-link" title="Instagram">📷</a>
          <a href="#" class="social-link" title="LinkedIn">in</a>
          <a href="#" class="social-link" title="WhatsApp">💬</a>
        </div>
      </div>
      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="#home">Home</a></li>
          <li><a href="#articles">News & Blog</a></li>
          <li><a href="#executives">Executives</a></li>
          <li><a href="#newsletter">Newsletter</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Programs</h4>
        <ul>
          <li><a href="#">Hackathons</a></li>
          <li><a href="#">Workshops</a></li>
          <li><a href="#">Mentorship</a></li>
          <li><a href="#">Tech Talks</a></li>
          <li><a href="#">Career Fair</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          <li><a href="mailto:tesa@oauife.edu.ng">tesa@oauife.edu.ng</a></li>
          <li><a href="#">Faculty of Technology</a></li>
          <li><a href="#">OAU, Ile-Ife</a></li>
          <li><a href="#">Osun State, Nigeria</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-divider"></div>
    <div class="footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> TESA OAU. All rights reserved. Made with ❤️ for <a href="#">OAU Engineers</a>.</p>
      <div class="oau-badge">🎓 Obafemi Awolowo University, Ile-Ife</div>
    </div>
  </div>
</footer>

<script>
  function scrollCarousel(dir) {
    const el = document.getElementById('execCarousel');
    el.scrollBy({ left: dir * 300, behavior: 'smooth' });
  }

  // Optional: show toast on subscribe success (can be triggered server-side via query param)
  const params = new URLSearchParams(window.location.search);
  if (params.get('subscribed') === 'true') {
    const toast = document.getElementById('toast');
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 4000);
  }
</script>

</body>
</html>
