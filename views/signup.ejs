<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up — TESA OAU</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/styles.css">
  <style>
    /* ─── AUTH PAGE LAYOUT ─────────────────── */
    body {
      min-height: 100vh;
      background: var(--blue);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
      position: relative;
      overflow-x: hidden;
    }

    .auth-bg-grid {
      position: fixed; inset: 0; z-index: 0;
      background-image:
        linear-gradient(rgba(37,99,235,0.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(37,99,235,0.07) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
    }
    .auth-glow-1 {
      position: fixed; top: -120px; right: -120px; z-index: 0;
      width: 520px; height: 520px; border-radius: 50%;
      background: radial-gradient(circle, rgba(37,99,235,0.25) 0%, transparent 70%);
      pointer-events: none;
    }
    .auth-glow-2 {
      position: fixed; bottom: -150px; left: -80px; z-index: 0;
      width: 440px; height: 440px; border-radius: 50%;
      background: radial-gradient(circle, rgba(245,158,11,0.1) 0%, transparent 70%);
      pointer-events: none;
    }

    /* ─── AUTH CARD ────────────────────────── */
    .auth-card {
      position: relative; z-index: 1;
      width: 100%; max-width: 500px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(37,99,235,0.25);
      border-radius: 24px;
      padding: 48px 44px;
      backdrop-filter: blur(16px);
    }
    .auth-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--blue-accent), var(--gold));
      border-radius: 24px 24px 0 0;
    }

    /* ─── LOGO ─────────────────────────────── */
    .auth-logo {
      display: flex; align-items: center; gap: 12px;
      text-decoration: none; margin-bottom: 36px;
    }
    .auth-logo-badge {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--blue-bright), var(--blue-light));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 18px; color: white; letter-spacing: 1px;
      box-shadow: 0 0 20px rgba(37,99,235,0.45);
    }
    .auth-logo-text strong {
      display: block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px; letter-spacing: 2px; color: var(--blue-light);
    }
    .auth-logo-text span {
      font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gray);
    }

    /* ─── HEADING ──────────────────────────── */
    .auth-heading {
      margin-bottom: 32px;
    }
    .auth-heading .eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--blue-light); font-weight: 700; margin-bottom: 10px;
    }
    .auth-heading .eyebrow i { font-size: 9px; color: var(--gold); }
    .auth-heading h1 {
      font-family: 'Playfair Display', serif;
      font-size: 32px; font-weight: 900;
      color: white; line-height: 1.15;
    }
    .auth-heading h1 em { font-style: italic; color: var(--blue-light); }
    .auth-heading p {
      margin-top: 8px; font-size: 14px;
      color: var(--gray); line-height: 1.6;
    }

    /* ─── NAME ROW ─────────────────────────── */
    .form-row-2 {
      display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
    }

    /* ─── FIELD ────────────────────────────── */
    .field { display: flex; flex-direction: column; gap: 7px; margin-bottom: 16px; }
    .field label {
      font-size: 11px; font-weight: 600; color: var(--gray-light);
      letter-spacing: 1px; text-transform: uppercase;
    }
    .field-wrap {
      position: relative; display: flex; align-items: center;
    }
    .field-wrap i.field-icon {
      position: absolute; left: 16px;
      color: var(--gray); font-size: 14px;
      pointer-events: none;
      transition: color .2s;
    }
    .field-wrap input {
      width: 100%;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 13px 16px 13px 44px;
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color .2s, background .2s;
    }
    .field-wrap input::placeholder { color: rgba(255,255,255,0.28); }
    .field-wrap input:focus {
      border-color: var(--blue-light);
      background: rgba(255,255,255,0.1);
    }
    .field-wrap input:focus + i.field-icon,
    .field-wrap:focus-within i.field-icon { color: var(--blue-light); }

    /* fix icon z-order — put icon after input in DOM */
    .field-wrap i.field-icon { z-index: 1; }

    /* password toggle */
    .pwd-toggle {
      position: absolute; right: 14px;
      background: none; border: none;
      color: var(--gray); font-size: 14px; cursor: pointer;
      padding: 4px; transition: color .2s;
      line-height: 1;
    }
    .pwd-toggle:hover { color: var(--blue-light); }

    /* ─── SUBMIT ────────────────────────────── */
    .btn-auth {
      width: 100%;
      background: var(--blue-accent); color: white;
      border: none; border-radius: 10px; padding: 15px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px; font-weight: 700; letter-spacing: .5px;
      cursor: pointer; transition: all .3s; margin-top: 8px;
      display: flex; align-items: center; justify-content: center; gap: 10px;
    }
    .btn-auth:hover {
      background: var(--blue-light);
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(37,99,235,0.45);
    }

    /* ─── DIVIDER ───────────────────────────── */
    .auth-divider {
      display: flex; align-items: center; gap: 14px;
      margin: 24px 0;
    }
    .auth-divider::before,
    .auth-divider::after {
      content: ''; flex: 1; height: 1px;
      background: rgba(255,255,255,0.08);
    }
    .auth-divider span { font-size: 11px; color: var(--gray); letter-spacing: 1px; text-transform: uppercase; }

    /* ─── FOOTER LINK ───────────────────────── */
    .auth-footer {
      text-align: center;
      margin-top: 28px;
      font-size: 14px; color: var(--gray);
    }
    .auth-footer a {
      color: var(--blue-light); font-weight: 600;
      text-decoration: none; transition: color .2s;
    }
    .auth-footer a:hover { color: var(--gold); }

    /* ─── ERROR MESSAGE ─────────────────────── */
    .auth-error {
      background: rgba(239,68,68,0.15);
      border: 1px solid rgba(239,68,68,0.35);
      border-radius: 10px; padding: 12px 16px;
      margin-bottom: 20px;
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: #FCA5A5;
    }
    .auth-error i { font-size: 14px; color: #F87171; flex-shrink: 0; }

    /* ─── TERMS NOTE ────────────────────────── */
    .terms-note {
      margin-top: 16px;
      font-size: 12px; color: var(--gray);
      text-align: center; line-height: 1.6;
    }
    .terms-note a { color: var(--blue-light); text-decoration: none; }
    .terms-note a:hover { text-decoration: underline; }

    @media (max-width: 520px) {
      .auth-card { padding: 36px 24px; }
      .form-row-2 { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <div class="auth-bg-grid"></div>
  <div class="auth-glow-1"></div>
  <div class="auth-glow-2"></div>

  <div class="auth-card">

    <!-- Logo -->
    <a href="/" class="auth-logo">
      <div class="auth-logo-badge">TESA</div>
      <div class="auth-logo-text">
        <strong>TESA OAU</strong>
        <span>Obafemi Awolowo University</span>
      </div>
    </a>

    <!-- Heading -->
    <div class="auth-heading">
      <div class="eyebrow">
        <i class="fa-solid fa-circle fa-xs"></i>
        Join the community
      </div>
      <h1>Create your <em>Account</em></h1>
      <p>Become part of OAU's premier engineering community.</p>
    </div>

    <!-- Error message (shown when passed from server) -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="auth-error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <%= error %>
      </div>
    <% } %>

    <!-- Signup Form -->
    <form action="/signup" method="POST">

      <!-- Name row -->
      <div class="form-row-2">
        <div class="field">
          <label for="firstName">First Name</label>
          <div class="field-wrap">
            <i class="fa-solid fa-user field-icon"></i>
            <input type="text" id="firstName" name="firstName" placeholder="e.g. Adaeze" required>
          </div>
        </div>
        <div class="field">
          <label for="lastName">Last Name</label>
          <div class="field-wrap">
            <i class="fa-solid fa-user field-icon"></i>
            <input type="text" id="lastName" name="lastName" placeholder="e.g. Okonkwo" required>
          </div>
        </div>
      </div>

      <!-- Username -->
      <div class="field">
        <label for="username">Username</label>
        <div class="field-wrap">
          <i class="fa-solid fa-at field-icon"></i>
          <input type="text" id="username" name="username" placeholder="Choose a username" required
            autocomplete="username">
        </div>
      </div>

      <!-- Email -->
      <div class="field">
        <label for="email">OAU Email Address</label>
        <div class="field-wrap">
          <i class="fa-solid fa-envelope field-icon"></i>
          <input type="email" id="email" name="email" placeholder="yourname@oauife.edu.ng" required
            autocomplete="email">
        </div>
      </div>

      <!-- Password -->
      <div class="field">
        <label for="password">Password</label>
        <div class="field-wrap">
          <i class="fa-solid fa-lock field-icon"></i>
          <input type="password" id="password" name="password" placeholder="Min. 8 characters" required
            autocomplete="new-password">
          <button type="button" class="pwd-toggle" onclick="togglePwd('password', this)" aria-label="Toggle password">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-auth">
        <i class="fa-solid fa-rocket"></i>
        Create Account
      </button>

      <p class="terms-note">
        By signing up, you agree to TESA OAU's
        <a href="#">Terms of Use</a> and <a href="#">Privacy Policy</a>.
      </p>
    </form>

    <div class="auth-divider"><span>or</span></div>

    <div class="auth-footer">
      Already have an account?
      <a href="/login"><i class="fa-solid fa-arrow-right-to-bracket"></i> Log in</a>
    </div>

  </div>

  <script>
    function togglePwd(inputId, btn) {
      const input = document.getElementById(inputId);
      const icon  = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }
  </script>

</body>
</html>
