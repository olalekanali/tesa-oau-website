<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Events — TESA OAU</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #0A1628;
      --blue-mid: #0D2657;
      --blue-bright: #1A4FC4;
      --blue-accent: #2563EB;
      --blue-light: #3B82F6;
      --gold: #F59E0B;
      --gold-light: #FCD34D;
      --white: #F8FAFF;
      --gray: #94A3B8;
      --gray-light: #CBD5E1;
      --text-dim: #64748B;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--white);
      color: var(--blue);
      overflow-x: hidden;
    }

    /* ─── HEADER ─────────────────────────── */
    header {
      position: fixed; top: 0; width: 100%; z-index: 999;
      background: rgba(10, 22, 40, 0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(37, 99, 235, 0.3);
      padding: 0 40px;
      display: flex; align-items: center; justify-content: space-between;
      height: 72px;
    }

    .logo {
      display: flex; align-items: center; gap: 12px;
      text-decoration: none;
    }
    .logo-badge {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--blue-bright), var(--blue-light));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px; color: white; letter-spacing: 1px;
      box-shadow: 0 0 20px rgba(37,99,235,0.5);
    }
    .logo-text { color: white; }
    .logo-text strong { display: block; font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 2px; color: var(--blue-light); }
    .logo-text span { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gray); }

    nav { display: flex; gap: 36px; }
    nav a {
      color: var(--gray-light); font-size: 13px; font-weight: 500;
      text-decoration: none; letter-spacing: 1px; text-transform: uppercase;
      transition: color .2s; position: relative;
    }
    nav a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 2px; background: var(--blue-light);
      transition: width .3s;
    }
    nav a:hover { color: white; }
    nav a:hover::after { width: 100%; }

    .header-cta {
      background: var(--blue-accent); color: white;
      border: none; padding: 10px 24px; border-radius: 6px;
      font-size: 13px; font-weight: 600; letter-spacing: 1px;
      text-transform: uppercase; cursor: pointer;
      transition: all .3s; text-decoration: none;
      display: inline-block;
    }
    .header-cta:hover { background: var(--blue-light); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(37,99,235,0.4); }

    /* ─── PAGE HEADER ─────────────────── */
    .page-header {
      min-height: 60vh;
      background: linear-gradient(135deg, var(--blue) 0%, var(--blue-mid) 100%);
      padding: 120px 40px 80px;
      position: relative; overflow: hidden;
      display: flex; align-items: center;
      margin-top: 72px;
    }

    .page-header::before {
      content: ''; position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(37,99,235,0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(37,99,235,0.08) 1px, transparent 1px);
      background-size: 60px 60px;
    }

    .page-header-inner {
      max-width: 1000px; margin: 0 auto;
      position: relative; z-index: 2; text-align: center;
    }

    .page-header-tag {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--gold); font-weight: 700; margin-bottom: 20px;
    }

    .page-header-tag::before { content: ''; width: 24px; height: 2px; background: var(--gold); }

    .page-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(48px, 5vw, 72px);
      line-height: 1.1; font-weight: 900;
      color: white; margin-bottom: 20px;
    }

    .page-header p {
      font-size: 17px; line-height: 1.8; color: var(--gray);
      max-width: 600px; margin: 0 auto;
    }

    /* ─── EVENTS GRID ──────────────────── */
    .events-section {
      padding: 80px 40px;
      background: var(--white);
    }

    .events-container {
      max-width: 1200px; margin: 0 auto;
    }

    .events-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 32px; margin-top: 40px;
    }

    .event-card {
      background: #F8FAFF; border: 1px solid #E2EAF8;
      border-radius: 16px; overflow: hidden;
      box-shadow: 0 2px 16px rgba(10,22,40,0.06);
      transition: all .3s;
      display: flex; flex-direction: column;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
    }

    .event-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 12px 36px rgba(10,22,40,0.12);
      border-color: rgba(37,99,235,0.28);
    }

    .event-card-header {
      height: 140px; background: linear-gradient(135deg, var(--blue-mid), var(--blue-bright));
      display: flex; align-items: center; justify-content: center;
      font-size: 56px; position: relative; overflow: hidden;
    }

    .event-status {
      position: absolute; top: 12px; right: 12px;
      background: var(--gold); color: var(--blue);
      padding: 4px 12px; border-radius: 100px;
      font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
    }

    .event-status.live {
      background: #4ADE80; color: white;
    }

    .event-card-body { padding: 24px; flex: 1; display: flex; flex-direction: column; }

    .event-date {
      font-size: 12px; font-weight: 700; color: var(--blue-accent);
      letter-spacing: 0.5px; margin-bottom: 10px;
    }

    .event-card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 20px; font-weight: 700; line-height: 1.3;
      color: var(--blue); margin-bottom: 10px;
    }

    .event-card p {
      font-size: 14px; line-height: 1.6; color: var(--text-dim);
      flex: 1; margin-bottom: 16px;
    }

    .event-details {
      display: flex; flex-direction: column; gap: 10px;
      padding-top: 14px; border-top: 1px solid #E8EEF8;
      margin-top: auto;
    }

    .event-detail-item {
      display: flex; align-items: center; gap: 8px;
      font-size: 13px; color: var(--text-dim);
    }

    .event-mode {
      display: inline-block;
      background: rgba(37,99,235,0.1); color: var(--blue-accent);
      padding: 4px 10px; border-radius: 4px;
      font-size: 11px; font-weight: 600;
    }

    /* ─── EMPTY STATE ────────────────────── */
    .empty-state {
      text-align: center; padding: 80px 40px;
    }

    .empty-state h2 {
      font-size: 28px; color: var(--blue); margin-bottom: 12px;
      font-family: 'Playfair Display', serif;
    }

    .empty-state p {
      font-size: 16px; color: var(--text-dim); margin-bottom: 32px;
    }

    .back-btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--blue-accent); color: white;
      padding: 12px 28px; border-radius: 8px;
      font-size: 14px; font-weight: 600; text-decoration: none;
      transition: all .3s;
    }

    .back-btn:hover { background: var(--blue-light); transform: translateY(-2px); }

    @media (max-width: 768px) {
      .events-grid { grid-template-columns: 1fr; }
      .page-header { padding: 100px 20px 60px; }
      header { padding: 0 20px; }
      nav { gap: 16px; font-size: 11px; }
    }
  </style>
</head>
<body>
  <!-- HEADER -->
  <header>
    <a href="/" class="logo">
      <div class="logo-badge">TE</div>
      <div class="logo-text">
        <strong>TESA</strong>
        <span>OAU</span>
      </div>
    </a>
    <nav>
      <a href="/">Home</a>
      <a href="/articles">Articles</a>
      <a href="/events">Events</a>
    </nav>
    <a href="/login" class="header-cta">Login</a>
  </header>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="page-header-inner">
      <div class="page-header-tag">Calendar</div>
      <h1>All Events</h1>
      <p>Discover all the exciting events, workshops, and programs organized by TESA OAU</p>
    </div>
  </div>

  <!-- EVENTS SECTION -->
  <section class="events-section">
    <div class="events-container">
      <% if (events && events.length > 0) { %>
        <div class="events-grid">
          <% events.forEach(event => { %>
            <a href="/events/<%= event._id %>" class="event-card">
              <div class="event-card-header">
                🚀
                <% if (event.status === 'live') { %>
                  <div class="event-status live">Live</div>
                <% } else { %>
                  <div class="event-status">Upcoming</div>
                <% } %>
              </div>
              <div class="event-card-body">
                <div class="event-date"><%= new Date(event.date).toLocaleDateString() %> at <%= event.startTime || 'TBA' %></div>
                <h3><%= event.title %></h3>
                <p><%= event.description %></p>
                <div class="event-details">
                  <div class="event-detail-item">
                    📍 <%= event.venueLocation || event.location || 'TBA' %>
                  </div>
                  <% if (event.mode) { %>
                    <div class="event-detail-item">
                      <span class="event-mode"><%= event.mode.charAt(0).toUpperCase() + event.mode.slice(1) %></span>
                    </div>
                  <% } %>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h2>No Events Yet</h2>
          <p>Check back soon for our upcoming events and programs</p>
          <a href="/" class="back-btn">← Back to Home</a>
        </div>
      <% } %>
    </div>
  </section>
</body>
</html>
